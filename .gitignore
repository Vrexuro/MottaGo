# ─── Claude Code ────────────────────────────────────────────────────────────
# Internal artifacts generated by Claude Code (screenshots, session config)
.claude/

# ─── IDE / Editor ───────────────────────────────────────────────────────────
# VS Code workspace settings — only extensions.json is safe to track
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Dependencies ───────────────────────────────────────────────────────────
# Covers root-level scripts and future backend/ packages
node_modules/
.pnp
.pnp.js

# ─── Build output ───────────────────────────────────────────────────────────
# Covers future backend/ and database/ build artifacts
dist/
dist-ssr/
build/

# ─── Test coverage ──────────────────────────────────────────────────────────
coverage/

# ─── Environment variables ──────────────────────────────────────────────────
# Never commit secrets or local environment overrides
.env
.env.local
.env.*.local

# ─── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── TypeScript ─────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── OS artifacts ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Supabase CLI local state ────────────────────────────────────────────────
supabase/.temp/
supabase/.branches/
