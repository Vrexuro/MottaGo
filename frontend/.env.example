# ──────────────────────────────────────────────────────────────────────────────
# MottaGo Frontend — Environment Variables
# Copy this file to .env and replace the placeholder values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase project URL (found in: Supabase Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (found in: Supabase Dashboard → Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Polling interval for real-time capacity data (milliseconds) — DL-04
VITE_POLLING_INTERVAL_MS=30000
